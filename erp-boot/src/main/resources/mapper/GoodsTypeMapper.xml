<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.GoodsTypeMapper">

    <resultMap id="GoodsTypeResultMap" type="com.erp.pojo.GoodsType">
        <id property="gid" column="gid"/>
        <result property="name" column="name"/>
        <result property="state" column="state"/>
    </resultMap>

    <select id="findAll" resultMap="GoodsTypeResultMap">
        SELECT * FROM goodstype WHERE state = '1'
        <if test="name != null and name != ''">
            AND name LIKE CONCAT('%', #{name}, '%')
        </if>
    </select>

    <insert id="add">
        INSERT INTO goodstype (name, state) VALUES (#{name}, '1')
    </insert>

    <delete id="deleteGoodsTypeById">
        UPDATE goodstype SET state = '0' WHERE gid = #{gid}
    </delete>

    <select id="findForUpdate" resultMap="GoodsTypeResultMap">
        SELECT * FROM goodstype WHERE gid = #{gid}
    </select>

    <update id="updateGoodstype">
        UPDATE goodstype SET name = #{name} WHERE gid = #{gid}
    </update>

    <select id="getCount" resultType="Integer">
        SELECT COUNT(*) FROM goodstype WHERE state = '1'
    </select>

    <insert id="addByGoodsType">
        INSERT INTO goodstype (name, state) VALUES (#{name}, '1')
    </insert>

    <select id="findGoodsType" resultMap="GoodsTypeResultMap">
        SELECT * FROM goodstype WHERE state = '1'
        <if test="name != null and name != ''">
            AND name = #{name}
        </if>
    </select>

    <select id="selectAll" resultMap="GoodsTypeResultMap">
        SELECT * FROM goodstype WHERE state = '1'
    </select>

</mapper>