<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.StoreMapper">

    <resultMap id="StoreResultMap" type="com.erp.pojo.Store">
        <id property="sid" column="sid"/>
        <result property="name" column="name"/>
        <result property="empId" column="empId"/>
        <result property="state" column="state"/>
    </resultMap>

    <select id="findAll" resultMap="StoreResultMap">
        SELECT * FROM store WHERE state = '1'
        <if test="name != null and name != ''">
            AND name LIKE CONCAT('%', #{name}, '%')
        </if>
    </select>

    <select id="findByEmpId" resultMap="StoreResultMap">
        SELECT * FROM store WHERE empId = #{empId} AND state = '1'
    </select>

    <insert id="add">
        INSERT INTO store (name, empId, state) VALUES (#{name}, #{empId}, '1')
    </insert>

    <delete id="delete">
        UPDATE store SET state = '0' WHERE sid = #{sid}
    </delete>

    <select id="getPojoById" resultMap="StoreResultMap">
        SELECT * FROM store WHERE sid = #{sid}
    </select>

    <update id="update">
        UPDATE store SET name = #{name}, empId = #{empId} WHERE sid = #{sid}
    </update>

    <select id="selectAll" resultMap="StoreResultMap">
        SELECT * FROM store WHERE state = '1'
    </select>

</mapper>